{
  "name": "@adapt-security/at-utils",
  "version": "0.19.0",
  "description": "A collection of CLI helper utilities for maintaining installations of the Adapt authoring tool.",
  "keywords": [
    "Adapt"
  ],
  "homepage": "https://github.com/adapt-security/at-utils",
  "bugs": {
    "url": "https://github.com/adapt-security/at-utils/issues"
  },
  "license": "MIT",
  "type": "module",
  "author": "Thomas Taylor <hello@tomtaylor.name>",
  "main": "index.js",
  "bin": "index.js",
  "repository": "github:adapt-security/at-utils",
  "dependencies": {
    "commander": "^14.0.3",
    "prompts": "^2.4.2",
    "semver": "^7.7.4"
  },
  "prerequisites": {
    "git": ">=2",
    "node": "24",
    "npm": "10"
  },
  "scripts": {
    "test": "node --test 'tests/**/*.spec.js'"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@semantic-release/git": "^10.0.1",
    "conventional-changelog-eslint": "^6.0.0",
    "semantic-release": "^25.0.2",
    "standard": "^17.1.0"
  },
  "release": {
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "eslint"
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "eslint"
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/github",
      "@semantic-release/git"
    ]
  },
  "standard": {
    "ignore": [
      "public"
    ]
  }
}
